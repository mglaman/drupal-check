{
    "name": "mglaman/drupal-check",
    "description": "CLI tool for running checks on a Drupal code base",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Matt Glaman",
            "email": "nmd.matt@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "composer/xdebug-handler": "^3.0",
        "jangregor/phpstan-prophecy": "^2.3",
        "jean85/pretty-package-versions": "^2.1",
        "mglaman/phpstan-drupal": "^2.0",
        "nette/neon": "^3.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "symfony/console": "^7.0",
        "symfony/process": "^7.0",
        "webflo/drupal-finder": "^1.3.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.4.0"
        }
    },
    "bin": [
        "drupal-check"
    ],
    "autoload": {
        "psr-4": {
            "DrupalCheck\\": "src"
        }
    },
    "extra": {
        "violinist": {
            "one_pull_request_per_package": 1
        }
    }
}
